# Copy this file to .env for local dev, and set the same keys in
# Vercel's Project Settings -> Environment Variables for production.
# NEVER commit a real .env file.

# A long random string. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Supabase: Project Settings -> Database -> Connection string (URI, "Transaction" pooler recommended)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# AI providers used for chat / guide generation / idea generation.
# Rotate these if they were ever exposed - see DEPLOYMENT_NOTES.md.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Your production URL once deployed, e.g. https://projectree.vercel.app
PUBLIC_APP_URL=

# Set automatically by Vercel - leave unset locally.
# VERCEL=1
